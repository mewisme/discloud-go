# --- Required ---

# Discord bot token (Developer Portal -> Bot -> Reset Token).
# Multiple bots: comma-separated; uploads are divided round-robin across them.
# DISCORD_BOT_TOKEN=token1,token2,token3
DISCORD_BOT_TOKEN=

# ID of the channel the bot uploads chunks to (right-click channel -> Copy ID).
DISCORD_CHANNEL_ID=

# --- Optional (docker-compose provides sensible defaults) ---

# Image tag for ghcr.io/mewisme/discloud and discloud-web (default: latest).
#DISCLOUD_TAG=v0.0.2

# Password for the bundled PostgreSQL container.
#POSTGRES_PASSWORD=discloud

# Public origin used in generated share links (defaults to the request host,
# or http://localhost:3000 in docker-compose).
#PUBLIC_BASE_URL=https://files.example.com

# --- Only needed when running the API outside docker-compose ---

#PORT=8080
#DATABASE_URL=postgres://discloud:discloud@localhost:5432/discloud
#VALKEY_URL=valkey://localhost:6379

# Frontend: origin of the Go API for server-side fetches and rewrites.
#API_URL=http://localhost:8080
