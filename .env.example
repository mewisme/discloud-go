# Required
DISCORD_BOT_TOKEN=token1,token2,...
DISCORD_CHANNEL_ID=channel_id
# Exact browser origin for CORS + cookies (no path).
WEB_ORIGIN=http://localhost:3000

# Local `go run` / make run (Compose injects these for containers):
#PORT=8080
#DATABASE_URL=postgres://discloud:discloud@localhost:5432/discloud?sslmode=disable
#VALKEY_URL=valkey://localhost:6379

# Optional — session/file-token HMAC root (≥32 chars).
# If unset, auto-generated and persisted to .app.secret (Docker: /data/.app.secret).
# Env wins over the file when both are present.
#APP_SECRET=change-me-to-a-long-random-secret!!

# Optional — public API origin (share links + web UI). Not the :3000 UI URL.
# After changing: docker compose up -d --force-recreate api web
#API_URL=http://localhost:8080

# Honor X-Forwarded-For / X-Real-IP only behind a trusted edge that strips
# client-supplied forwarding headers (e.g. Cloudflare path-proxy).
#TRUST_PROXY=true

# Abuse protection (Phase 4). Zero rate limits / quotas = unlimited.
#RATE_LIMIT_UPLOAD_PER_MIN=60
#RATE_LIMIT_DOWNLOAD_PER_MIN=120
#MAX_USER_BYTES=0
#MAX_ANON_UPLOADS_PER_DAY=50
#MAX_ANON_BYTES_PER_DAY=2147483648
#MAX_RAW_UPLOAD_BYTES=0
# Turnstile (optional). Set both for anon upload CAPTCHA.
#CAPTCHA_SECRET=
# Web (runtime): CAPTCHA_KEY=<Turnstile site key>
# CAPTCHA_KEY=

#DISCLOUD_TAG=latest
#POSTGRES_PASSWORD=discloud