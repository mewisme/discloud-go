FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/ cmd/
COPY internal/ internal/
ARG VERSION=dev
RUN CGO_ENABLED=0 go build -trimpath -ldflags "-s -w -X main.version=${VERSION}" -o /discloud ./cmd/discloud

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /discloud /discloud
# Seed /data so a first-mount named volume inherits nonroot ownership.
COPY --chown=65532:65532 data /data
WORKDIR /data
USER nonroot
EXPOSE 8080
ENTRYPOINT ["/discloud"]
